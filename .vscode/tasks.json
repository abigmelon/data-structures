{
    "tasks": [
        {
            "label": "终止旧进程",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "taskkill /f /im ${fileBasenameNoExtension}.exe 2>nul & exit /b 0"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [],
            "presentation": {
                "echo": false,
                "reveal": "silent",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": false
            },
            "detail": "终止正在运行的旧程序（如果存在）"
        },
        {
            "type": "cppbuild",
            "label": "编译",
            "command": "D:\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "编译当前 C 文件"
        },
        {
            "label": "运行程序",
            "type": "process",
            "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "focus": true,
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "运行编译好的程序"
        },
        {
            "label": "编译并运行",
            "dependsOn": [
                "终止旧进程",
                "编译",
                "运行程序"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "detail": "一键终止旧进程→编译→运行当前程序"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:\\mingw64\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}